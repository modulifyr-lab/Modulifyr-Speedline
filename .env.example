# ─────────────────────────────────────────────
# FIREBASE (client-side)
# Firebase Console → Project Settings → General → Your apps
# ─────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─────────────────────────────────────────────
# FIREBASE WEBHOOK SERVICE USER (server-side only)
# Firebase Console → Authentication → Add user
# Use: webhook@speedline.internal + strong random password
# ─────────────────────────────────────────────
FIREBASE_WEBHOOK_EMAIL=webhook@speedline.internal
FIREBASE_WEBHOOK_PASSWORD=

# ─────────────────────────────────────────────
# PADDLE (replaces Stripe — works with Nepal)
#
# 1. Sign up at paddle.com
# 2. Complete KYC — set payout method to Wise or PayPal
# 3. Dashboard → Developer Tools → Authentication → API keys
# 4. Start in sandbox, switch to production when ready
#
# PADDLE_ENVIRONMENT: 'sandbox' for testing, 'production' for live
# PADDLE_API_KEY: your secret API key (never prefix with NEXT_PUBLIC_)
# PADDLE_WEBHOOK_SECRET: from Dashboard → Developer Tools → Notifications → your endpoint
# ─────────────────────────────────────────────
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# APP
# Local: http://localhost:3000
# Production: https://speedline.modulifyr.com
# ─────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000